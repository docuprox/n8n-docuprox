{
  "name": "n8n-nodes-docuprox",
  "version": "1.0.9",
  "description": "An n8n community node for AI-powered document processing via the DocuProx API. Extract structured data from documents using manual or AI-generated prompts — no template required. Supports real-time processing and high-volume batch jobs.",
  "keywords": [
    "n8n",
    "n8n-nodes",
    "n8n-community-node-package",
    "docuprox",
    "document-processing",
    "document-extraction",
    "document-ai",
    "ai-extraction",
    "ai-agent",
    "data-extraction",
    "document-automation",
    "batch-processing",
    "structured-data"
  ],
  "license": "MIT",
  "homepage": "https://github.com/docuprox/n8n-docuprox",
  "author": {
    "name": "DocuProx",
    "email": "mail@docuprox.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docuprox/n8n-docuprox.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "if exist nodes\\DocuProx\\*.svg xcopy /Y nodes\\DocuProx\\*.svg dist\\nodes\\DocuProx\\",
    "dev": "tsc --watch",
    "format": "prettier nodes --write",
    "lint": "eslint nodes package.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DocuProxApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DocuProx/DocuProx.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^4.8.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
